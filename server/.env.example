# Copy this file to .env and fill in your values
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: pin a specific Gemini model to avoid API model-name mismatches.
# Recommended: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash
# Comma-separated list of allowed frontend origins for CORS.
# Example: http://localhost:5173,https://your-app.vercel.app
CLIENT_ORIGINS=http://localhost:5173,http://localhost:4173
# Optional: allow all Vercel preview deployment URLs (*.vercel.app)
ALLOW_VERCEL_PREVIEWS=false
PORT=3001
NODE_ENV=development
